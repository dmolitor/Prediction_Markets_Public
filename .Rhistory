# kalshi_skew, kalshi_variance,
kalshi_mean_c,
kalshi_median_c, kalshi_mode_c,
kalshi_skew_c, kalshi_variance_c,
kalshi_kurt_c, kalshi_skew2_c,
# ticker_name,
shock) %>% na.omit()
