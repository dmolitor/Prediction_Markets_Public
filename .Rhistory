rm(list = ls())
# ----------------------------
# 1) Parameters (FILL THESE IN)
# ----------------------------
A     <- 1.0
alpha <- 0.3
delta <- 0.05
rho   <- 0.05
sigma <- 2.0
dt <- 0.1
N  <- 700
tgrid <- seq(0, by = dt, length.out = N + 1)
k0 <- 1.0  # <-- given initial capital in the problem
# ----------------------------
# 2) Production
# ----------------------------
f  <- function(k) A * k^alpha
fp <- function(k) A * alpha * k^(alpha - 1)
# ----------------------------
# 3) Baseline steady state (G -> 0)
#    From cdot=0: fp(k*) - delta - rho = 0
# ----------------------------
k_star <- ((A * alpha) / (rho + delta))^(1 / (1 - alpha))
c_ss0  <- f(k_star) - delta * k_star  # baseline (G=0)
# ----------------------------
# 4) Build G_n sequences for each case (discrete-time, matches Euler grid)
# ----------------------------
build_G <- function(case_id, N, c_ss0, Gperm_share = 0.20, decay = 0.95) {
G <- numeric(N + 1)
if (case_id == 1) {
# Case 1: baseline, G_n = 0 for all n
G[] <- 0
}
if (case_id == 2) {
# Case 2: permanent increase (common spec: G_0 = 0, G_n = 0.20*c_ss for n>=1)
# If your handout uses a different rule, change it here.
G[1] <- 0
G[2:(N + 1)] <- Gperm_share * c_ss0
}
if (case_id == 3) {
# Case 3 (your screenshot):
# G_0 = 0
# G_1 = 0.20 c_ss
# G_{n+1} = 0.95 G_n for n >= 1
G[1] <- 0
G[2] <- 0.20 * c_ss0
if (N + 1 >= 3) {
for (i in 2:N) { # i corresponds to n (1-indexed shift)
G[i + 1] <- decay * G[i]
}
}
}
G
}
# ----------------------------
# 5) Euler-forward simulator given c0 and a G sequence
# ----------------------------
simulate_path <- function(c0, k0, dt, N, G) {
k <- numeric(N + 1)
c <- numeric(N + 1)
k[1] <- k0
c[1] <- c0
for (i in 1:N) {
# state must stay positive
if (!is.finite(k[i]) || !is.finite(c[i]) || k[i] <= 0 || c[i] <= 0) {
k[i:(N + 1)] <- NA
c[i:(N + 1)] <- NA
break
}
kdot <- f(k[i]) - c[i] - G[i] - delta * k[i]
cdot <- (1 / sigma) * (fp(k[i]) - delta - rho) * c[i]
k[i + 1] <- k[i] + dt * kdot
c[i + 1] <- c[i] + dt * cdot
}
list(k = k, c = c)
}
# ----------------------------
# 6) Shooting: bracket + uniroot on terminal capital condition
#    Target depends on case:
#      - Case 1/2: converge to steady state under that constant G (same k*, different c_ss)
#      - Case 3: converge back to baseline steady state (k*, c_ss0) as G->0
# ----------------------------
shoot_c0 <- function(k0, G, case_id) {
# Long-run G for constant cases; for case 3 target baseline
G_inf <- if (case_id %in% c(1,2)) G[N + 1] else 0
c_target <- f(k_star) - delta * k_star - G_inf
k_target <- k_star
residual <- function(c0) {
path <- simulate_path(c0, k0, dt, N, G)
kN <- path$k[N + 1]
if (is.na(kN) || !is.finite(kN)) return(1e6)
kN - k_target
}
# feasible-ish center: output net of depreciation and G at t=0
c_center <- max(1e-8, 0.8 * (f(k0) - delta * k0 - G[1]))
c_low    <- max(1e-8, 0.05 * c_center)
c_high   <- max(1e-8, 2.50 * c_center)
r_low  <- residual(c_low)
r_high <- residual(c_high)
tries <- 0
while (is.finite(r_low) && is.finite(r_high) && r_low * r_high > 0 && tries < 60) {
c_high <- c_high * 1.5
r_high <- residual(c_high)
tries <- tries + 1
}
if (!is.finite(r_low) || !is.finite(r_high) || r_low * r_high > 0) {
return(list(c0 = NA, c_target = c_target, ok = FALSE))
}
sol <- uniroot(residual, lower = c_low, upper = c_high, tol = 1e-10)
list(c0 = sol$root, c_target = c_target, ok = TRUE)
}
# ----------------------------
# 7) Saddle path curve at t=0: compute c0(k0) by shooting for a grid of k0s
# ----------------------------
compute_saddle_curve <- function(G, case_id, kmin = 0.5, kmax = 1.5, npts = 35) {
k_grid <- seq(kmin * k_star, kmax * k_star, length.out = npts)
c_grid <- rep(NA_real_, npts)
for (j in seq_along(k_grid)) {
sol <- shoot_c0(k_grid[j], G, case_id)
c_grid[j] <- sol$c0
}
list(k = k_grid, c = c_grid)
}
# ----------------------------
# 8) Phase diagram helpers (vector field only for constant-G cases)
# ----------------------------
kdot_fun <- function(k, c, Gconst) f(k) - c - Gconst - delta * k
cdot_fun <- function(k, c) (1 / sigma) * (fp(k) - delta - rho) * c
plot_vector_field <- function(k_rng, c_rng, Gconst, nk = 18, nc = 18) {
kk <- seq(k_rng[1], k_rng[2], length.out = nk)
cc <- seq(c_rng[1], c_rng[2], length.out = nc)
K <- rep(kk, each = length(cc))
C <- rep(cc, times = length(kk))
U <- kdot_fun(K, C, Gconst)
V <- cdot_fun(K, C)
# normalize arrows so lengths are comparable
speed <- sqrt(U^2 + V^2)
speed[speed == 0] <- 1
U <- U / speed
V <- V / speed
# scale to grid spacing
sx <- (k_rng[2] - k_rng[1]) / (nk * 2)
sy <- (c_rng[2] - c_rng[1]) / (nc * 2)
arrows(
x0 = K, y0 = C,
x1 = K + sx * U, y1 = C + sy * V,
length = 0.05, angle = 20, col = "gray60"
)
}
# ----------------------------
# 9) Loop over cases and write ONE PDF
# ----------------------------
case_names <- c(
"Case 1: Baseline (G_n = 0)",
"Case 2: Permanent increase in G (default: G_n = 0.20*c_ss0 for n>=1)",
"Case 3: Temporary persistent G (G0=0, G1=0.20*c_ss0, G_{n+1}=0.95 G_n)"
)
pdf("ngm_all_cases_results.pdf", width = 11, height = 8.5)
