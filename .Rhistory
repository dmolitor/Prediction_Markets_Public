c_target <- f(k_star) - delta * k_star - G_inf
G_inf
# Shoot for the requested initial k0
shot <- shoot_c0(k0, G, case_id)
shot
c0_star <- shot$c0
c0_star
# Simulate transition path
path <- if (is.finite(c0_star)) simulate_path(c0_star, k0, dt, N, G) else list(k = rep(NA, N+1), c = rep(NA, N+1))
path
