G <- build_G(case_id, N, c_ss0)
# Targets for labeling
G_inf <- if (case_id %in% c(1,2)) G[N + 1] else 0
c_target <- f(k_star) - delta * k_star - G_inf
# Shoot for the requested initial k0
shot <- shoot_c0(k0, G, case_id)
# Shoot for the requested initial k0
shot <- shoot_c0(k0, G, case_id)
c0_star <- shot$c0
# Simulate transition path
path <- if (is.finite(c0_star)) simulate_path(c0_star, k0, dt, N, G) else list(k = rep(NA, N+1), c = rep(NA, N+1))
# Saddle path curve at t=0
saddle <- compute_saddle_curve(G, case_id, kmin = 0.5, kmax = 1.5, npts = 35)
# Choose plotting ranges
k_rng <- range(c(k0, k_star, saddle$k), na.rm = TRUE)
k_rng <- c(0.9 * k_rng[1], 1.1 * k_rng[2])
# For c-range, use target and saddle and simulated path
c_rng <- range(c(c_target, saddle$c, path$c), na.rm = TRUE)
c_rng <- c(max(1e-8, 0.85 * c_rng[1]), 1.15 * c_rng[2])
# Loci for constant G (cases 1 & 2): kdot=0 locus and cdot=0 vertical line
# For case 3, still draw baseline cdot=0 line at k=k*, but kdot=0 locus is time-varying
k_locus_grid <- seq(k_rng[1], k_rng[2], length.out = 300)
G_for_locus <- if (case_id %in% c(1,2)) G_inf else 0
c_kdot0 <- f(k_locus_grid) - G_for_locus - delta * k_locus_grid
# ----------------------------
# Page 1: Phase diagram (k,c)
# ----------------------------
par(mfrow = c(1,1), mar = c(4.5, 4.5, 3.5, 1.5))
plot(NA, xlim = k_rng, ylim = c_rng, xlab = "k", ylab = "c",
main = paste0(case_names[case_id], "\nPhase diagram with loci, saddle path, transition path"))
# Vector field only for cases 1 and 2 (autonomous)
if (case_id %in% c(1,2)) {
plot_vector_field(k_rng, c_rng, Gconst = G_inf, nk = 18, nc = 18)
}
# kdot=0 locus (for constant G; for case 3 show baseline kdot=0 locus as a reference)
lines(k_locus_grid, c_kdot0, lwd = 2, lty = 2)
# cdot=0 locus: k = k*
abline(v = k_star, lwd = 2, lty = 3)
# Saddle path (curve at t=0)
lines(saddle$k, saddle$c, lwd = 3)
# Transition path from (k0, c0*)
if (is.finite(c0_star)) lines(path$k, path$c, lwd = 3)
# Mark steady state target and initial point
points(k_star, c_target, pch = 19, cex = 1.1)
points(k0, c0_star, pch = 4, cex = 1.2, lwd = 2)
legend("topright",
